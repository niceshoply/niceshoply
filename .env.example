APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
APP_FORCE_HTTPS=false

APP_LOCALE=zh_cn
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily,json
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

DB_CONNECTION=mysql
DB_PREFIX=nice_
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=niceshoply
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# 商品搜索（Laravel Scout）。默认 collection（无需外部服务，沿用 DB 检索）。
# 生产接入 Meilisearch：SCOUT_DRIVER=meilisearch、SCOUT_ENABLED=true，
# 然后执行：./scripts/prod-post-deploy.sh scout-import
# （或手动：php artisan scout:import "NiceShoply\Common\Models\Product"）
SCOUT_DRIVER=collection
SCOUT_ENABLED=false
SCOUT_QUEUE=true
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

SENTRY_LARAVEL_DSN=
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.1

# GeoLite2 离线 IP 库下载地址（留空使用内置镜像；可指向 MaxMind 官方带 license_key 的 .mmdb 直链）
GEOLITE2_DOWNLOAD_URL=

ACTIVITY_LOG_ENABLED=true
ACTIVITY_LOG_RETENTION_DAYS=90
